# Copy this file to .env.local and fill real values. Do not commit .env.local.

DATABASE_URL=
RUN_TARGET=all

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Optional city credentials and network settings.
GYS_ID=
GYS_PW=
ISDC_ID=
ISDC_PW=
GYT_PROXY_URL=
GYT_USE_CURL_CFFI=1
GYT_DEBUG_DUMP=1
FORCE_GOYANG_CRAWL=false

# Leave blank for local fallback unless this PC should route via another Tailscale node.
CRAWL_TAILSCALE_EXIT_NODE=
GYT_TAILSCALE_EXIT_NODE=
